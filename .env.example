# ── LiveKit ──────────────────────────────────────────────────────────────────
# Get from https://cloud.livekit.io → Project → Settings → API Keys
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxxxx
LIVEKIT_API_SECRET=your_api_secret_here

# ── LLM ──────────────────────────────────────────────────────────────────────
# Groq (primary — fastest free tier): https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI (fallback): https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── LLM: Anthropic (Claude) is preferred ─────────────────────────────────────
# When ANTHROPIC_API_KEY is set the agent uses Claude via livekit-plugins-anthropic
# — reliable tool-calling + low latency on Haiku (best for voice). This is the
# recommended path; it fixes the tool-call hallucination and slowness seen on Groq.
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-haiku-4-5

# ── LLM fallback: Groq / OpenAI-compatible (used only if ANTHROPIC_API_KEY unset)
# llama-3.3-70b-versatile does acceptable tool-calling but hits a 12k TPM free-tier
# cap (429); llama-3.1-8b-instant is faster but FAKES tool calls — avoid for booking.
LLM_MODEL=llama-3.3-70b-versatile
LLM_BASE_URL=https://api.groq.com/openai/v1

# ── Speech (Deepgram) ─────────────────────────────────────────────────────────
# https://console.deepgram.com/project → API Keys
DEEPGRAM_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# STT model (nova-2 is best free-tier balance)
DEEPGRAM_STT_MODEL=nova-2

# TTS voice. NOTE: some Deepgram projects only have aura-1 access — aura-2-*
# then returns 403. aura-asteria-en (aura-1) works on the free tier.
DEEPGRAM_TTS_VOICE=aura-asteria-en

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
# For local dev: matches docker-compose.yml defaults
DATABASE_URL=postgresql+asyncpg://voice_agent:voice_agent_dev@localhost:5432/voice_agent

# ── Twilio (warm transfer) ────────────────────────────────────────────────────
# https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The phone number Twilio dials FROM (your Twilio number, E.164 format)
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# The human agent's phone number Twilio dials TO (E.164 format)
TWILIO_HUMAN_AGENT_NUMBER=+1XXXXXXXXXX

# Public URL where your FastAPI app is reachable (for Twilio webhooks).
# In dev: use ngrok — `ngrok http 8000` — e.g. https://abc123.ngrok-free.app
# The agent reads this at startup, so RESTART the agent after changing it.
# Free ngrok URLs change on every restart — keep this in sync.
PUBLIC_BASE_URL=https://your-ngrok-url.ngrok-free.app

# ── LiveKit SIP warm-transfer bridge (optional) ───────────────────────────────
# Dials the human into the SAME LiveKit room as the caller (real audio bridge).
# Requires a Twilio Elastic SIP Trunk (Console → Elastic SIP Trunking):
#   Termination SIP URI + a Credential List (username/password).
# See CLAUDE.md → "Twilio + warm transfer" for full setup.
TWILIO_SIP_TERMINATION_URI=your-trunk.pstn.twilio.com
TWILIO_SIP_USERNAME=your_sip_credential_username
TWILIO_SIP_PASSWORD=your_sip_credential_password

# Run: PYTHONPATH=backend python backend/scripts/setup_sip_trunk.py
# It prints a trunk id — paste it here, then restart the agent.
# If unset, warm transfer falls back to Twilio REST (rings human, no audio bridge).
LIVEKIT_SIP_TRUNK_ID=

# ── App ───────────────────────────────────────────────────────────────────────
# Environment: development | production
APP_ENV=development

# Port FastAPI listens on
PORT=8000

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
